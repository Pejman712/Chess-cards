#!/usr/bin/env bash
#
# install - set up everything Chess-cards needs to run.
#
#   ./install            install Python deps into the current environment
#   ./install --venv     create a local .venv and install there
#
# Required deps (pygame, python-chess) come from requirements.txt.
# Stockfish powers the "vs Computer" mode; it is optional - the game falls
# back to a basic built-in AI if no engine is found, so we never fail the
# install just because Stockfish could not be fetched.

set -euo pipefail

# Resolve the project directory so the script works from anywhere.
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_DIR"

USE_VENV=0
[ "${1:-}" = "--venv" ] && USE_VENV=1

say()  { printf '\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[error]\033[0m %s\n' "$*" >&2; }

# ---------------------------------------------------------------- Python check
if command -v python3 >/dev/null 2>&1; then
    PY=python3
elif command -v python >/dev/null 2>&1; then
    PY=python
else
    err "Python 3 is required but was not found on PATH. Install it and re-run."
    exit 1
fi
say "Using Python: $($PY --version 2>&1) ($(command -v $PY))"

# ---------------------------------------------------------- optional virtualenv
if [ "$USE_VENV" = 1 ]; then
    say "Creating virtual environment in ./.venv"
    "$PY" -m venv .venv
    # shellcheck disable=SC1091
    source .venv/bin/activate
    PY=python
fi

# --------------------------------------------------------- Python dependencies
say "Upgrading pip"
"$PY" -m pip install --upgrade pip

say "Installing Python dependencies from requirements.txt"
"$PY" -m pip install -r requirements.txt

# -------------------------------------------------------------------- Stockfish
# The game looks for $STOCKFISH_PATH first, then engine/stockfish_bin.
ENGINE_BIN="$PROJECT_DIR/engine/stockfish_bin"

if [ -n "${STOCKFISH_PATH:-}" ] && [ -x "${STOCKFISH_PATH:-}" ]; then
    say "Stockfish provided via \$STOCKFISH_PATH: $STOCKFISH_PATH"
elif [ -f "$ENGINE_BIN" ]; then
    chmod +x "$ENGINE_BIN"
    say "Stockfish already present at engine/stockfish_bin"
elif command -v stockfish >/dev/null 2>&1; then
    # A system-wide Stockfish exists; link it into the path the game expects.
    SYS_SF="$(command -v stockfish)"
    mkdir -p "$PROJECT_DIR/engine"
    ln -sf "$SYS_SF" "$ENGINE_BIN"
    say "Linked system Stockfish ($SYS_SF) -> engine/stockfish_bin"
else
    # Best-effort install via whatever package manager is available. Any
    # failure here is non-fatal: the game runs on its basic AI without it.
    say "Stockfish not found; attempting to install it (optional)"
    INSTALLED=0
    if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get update -y && sudo apt-get install -y stockfish && INSTALLED=1 || true
    elif command -v dnf >/dev/null 2>&1; then
        sudo dnf install -y stockfish && INSTALLED=1 || true
    elif command -v pacman >/dev/null 2>&1; then
        sudo pacman -S --noconfirm stockfish && INSTALLED=1 || true
    elif command -v brew >/dev/null 2>&1; then
        brew install stockfish && INSTALLED=1 || true
    fi

    if [ "$INSTALLED" = 1 ] && command -v stockfish >/dev/null 2>&1; then
        mkdir -p "$PROJECT_DIR/engine"
        ln -sf "$(command -v stockfish)" "$ENGINE_BIN"
        say "Linked installed Stockfish -> engine/stockfish_bin"
    else
        warn "Could not install Stockfish automatically."
        warn "Player-vs-Computer will use the basic built-in AI."
        warn "To enable Stockfish later: install it and either place/symlink the"
        warn "binary at engine/stockfish_bin or set STOCKFISH_PATH=/path/to/stockfish"
    fi
fi

# ------------------------------------------------------------------------- done
echo
say "Done. Launch the game with:"
if [ "$USE_VENV" = 1 ]; then
    echo "    source .venv/bin/activate && python main.py"
else
    echo "    $PY main.py"
fi
