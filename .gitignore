# Stockfish engine binary (large, platform-specific - download per machine).
# See requirements.txt / README for how to fetch it.
engine/

# Python bytecode
__pycache__/
*.pyc

# Local settings + saved game
config.json
savegame.pkl

# Godot editor cache (regenerated on open, not source)
godot/.godot/

# Stockfish binary bundled for the Godot AI (same reasoning as engine/ above)
godot/engine/

# Godot save/config written to user:// at runtime
godot/.local/
